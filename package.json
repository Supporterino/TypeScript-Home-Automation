{
  "name": "ts-home-automation",
  "version": "0.0.0",
  "description": "TypeScript-based home automation framework for Zigbee2MQTT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/zigbee/index.d.ts",
      "import": "./dist/types/zigbee/index.js"
    },
    "./types/shelly": {
      "types": "./dist/types/shelly.d.ts",
      "import": "./dist/types/shelly.js"
    },
    "./types/nanoleaf": {
      "types": "./dist/types/nanoleaf.d.ts",
      "import": "./dist/types/nanoleaf.js"
    },
    "./types/weather": {
      "types": "./dist/types/weather.d.ts",
      "import": "./dist/types/weather.js"
    },
    "./types/notification": {
      "types": "./dist/types/notification.d.ts",
      "import": "./dist/types/notification.js"
    }
  },
  "bin": {
    "ts-ha": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run --watch src/standalone.ts",
    "start": "bun run src/standalone.ts",
    "test": "bun test",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "build:web-ui": "bun run scripts/generate-icon.ts && bun run scripts/build-web-ui.ts",
    "prebuild": "bun run scripts/generate-icon.ts && bun run scripts/build-web-ui.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "docker:build": "docker build -t home-automation .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "keywords": [
    "home-automation",
    "mqtt",
    "zigbee2mqtt",
    "zigbee",
    "shelly",
    "iot",
    "smart-home",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Supporterino/TypeScript-Home-Automation"
  },
  "license": "GPL-3.0-only",
  "dependencies": {
    "@mantine/core": "^9.0.2",
    "@mantine/hooks": "^9.0.2",
    "@opentui/core": "^0.1.99",
    "@opentui/react": "^0.2.0",
    "@tabler/icons-react": "^3.41.1",
    "cron": "^4.4.0",
    "hap-nodejs": "^0.14.3",
    "hono": "^4.12.14",
    "mqtt": "^5.15.1",
    "pino": "^10.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "pino-pretty": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "pino-pretty": {
      "optional": true
    }
  }
}
