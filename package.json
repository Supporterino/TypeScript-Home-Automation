{
  "name": "typescript-home-automation",
  "version": "1.0.0",
  "description": "TypeScript-based home automation framework for Zigbee2MQTT",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t home-automation .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "cron": "^4.3.0",
    "mqtt": "^5.10.0",
    "pino": "^9.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.0"
  }
}
